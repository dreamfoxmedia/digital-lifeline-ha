#!/bin/bash

TARGET="/config/custom_components/digital_lifeline"
SOURCE="/integration/custom_components/digital_lifeline"

# Versie uitlezen uit manifest
VERSION=$(grep '"version"' "${SOURCE}/manifest.json" | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "onbekend")

echo "========================================"
echo " Digital Lifeline Add-on gestart"
echo " Integratie versie: ${VERSION}"
echo " Tijdstip: $(date '+%Y-%m-%d %H:%M:%S')"
echo "========================================"

if [ -d "$TARGET" ]; then
    CURRENT=$(grep '"version"' "${TARGET}/manifest.json" | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "onbekend")
    echo "[INFO] Bestaande installatie gevonden (versie ${CURRENT}) - bijwerken naar ${VERSION}..."
    rm -rf "$TARGET"
else
    echo "[INFO] Eerste installatie..."
fi

mkdir -p "$TARGET"
if cp -r "$SOURCE/." "$TARGET/"; then
    echo "[OK]   Bestanden gekopieerd naar ${TARGET}"
else
    echo "[FOUT] Kopiëren mislukt!"
    exit 1
fi

# Bestandslijst loggen
FILE_COUNT=$(find "$TARGET" -type f | wc -l)
echo "[INFO] ${FILE_COUNT} bestanden geïnstalleerd"
echo "[OK]   Integratie versie ${VERSION} is gereed"
echo ""
echo "[INFO] Herstart Home Assistant om de integratie te activeren."
echo "[INFO] Ga daarna naar: Instellingen → Apparaten & Diensten → Integratie toevoegen → Digital Lifeline"
echo "========================================"

# Actief houden — elke minuut een heartbeat in het logboek
COUNTER=0
while true; do
    sleep 60
    COUNTER=$((COUNTER + 1))
    if [ $((COUNTER % 60)) -eq 0 ]; then
        echo "[INFO] Add-on actief ($(( COUNTER )) minuten) - $(date '+%Y-%m-%d %H:%M:%S')"
    fi
done
