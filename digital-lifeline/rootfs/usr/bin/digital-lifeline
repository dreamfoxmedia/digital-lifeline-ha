#!/bin/bash

TARGET="/config/custom_components/digital_lifeline"
SOURCE="/integration/custom_components/digital_lifeline"

echo "[INFO] Digital Lifeline: integratie installeren..."

if [ -d "$TARGET" ]; then
    echo "[INFO] Bestaande installatie gevonden - bijwerken..."
    rm -rf "$TARGET"
fi

mkdir -p "$TARGET"
cp -r "$SOURCE/." "$TARGET/"

echo "[INFO] Installatie geslaagd!"
echo "[INFO] Herstart Home Assistant en voeg de integratie toe via:"
echo "[INFO]   Instellingen -> Apparaten & Diensten -> Integratie toevoegen"
echo "[INFO]   Zoek op: Digital Lifeline"

while true; do sleep 3600; done
